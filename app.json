{
  "id": "com.glacialengineering.homey.frigate",
  "version": "1.0.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "platforms": ["local"],
  "brandColor": "#2563EB",
  "name": {
    "en": "Frigate"
  },
  "description": {
    "en": "Trigger Homey Flows from Frigate MQTT events"
  },
  "category": ["security"],
  "tags": {
    "en": ["frigate", "camera", "security", "mqtt", "nvr"]
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "permissions": [],
  "author": {
    "name": "Glacial Engineering",
    "email": "github@glacial.engineering"
  },
  "drivers": [
    {
      "id": "frigate-camera",
      "name": {
        "en": "Frigate Camera"
      },
      "class": "camera",
      "capabilities": [],
      "pair": [
        {
          "id": "start",
          "navigation": {
            "next": "list_devices"
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ]
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "tracked_object_update",
        "title": { "en": "Tracked object metadata updated" },
        "titleFormatted": { "en": "Tracked object [[update_type]] update on [[camera]]" },
        "args": [
          {
            "name": "update_type",
            "type": "dropdown",
            "title": { "en": "Update type" },
            "values": [
              { "id": "any", "label": { "en": "Any" } },
              { "id": "description", "label": { "en": "Description" } },
              { "id": "face", "label": { "en": "Face" } },
              { "id": "lpr", "label": { "en": "License plate" } },
              { "id": "classification", "label": { "en": "Classification" } }
            ]
          },
          { "name": "camera", "type": "text", "title": { "en": "Camera" }, "placeholder": { "en": "Leave empty for any camera" }, "required": false }
        ],
        "tokens": [
          { "name": "id", "type": "string", "title": { "en": "Object/Event ID" } },
          { "name": "update_type", "type": "string", "title": { "en": "Update Type" } },
          { "name": "camera", "type": "string", "title": { "en": "Camera" } },
          { "name": "timestamp", "type": "number", "title": { "en": "Timestamp" } },
          { "name": "description", "type": "string", "title": { "en": "Description" } },
          { "name": "name", "type": "string", "title": { "en": "Name" } },
          { "name": "score", "type": "number", "title": { "en": "Score" } },
          { "name": "plate", "type": "string", "title": { "en": "Plate" } },
          { "name": "model", "type": "string", "title": { "en": "Model" } },
          { "name": "sub_label", "type": "string", "title": { "en": "Sub Label" } },
          { "name": "attribute", "type": "string", "title": { "en": "Attribute" } },
          { "name": "raw_json", "type": "string", "title": { "en": "Raw JSON" } }
        ]
      },
      {
        "id": "object_description_updated",
        "title": { "en": "Object description updated" },
        "titleFormatted": { "en": "Object description updated on [[camera]]" },
        "args": [
          { "name": "camera", "type": "text", "title": { "en": "Camera" }, "placeholder": { "en": "Leave empty for any camera" }, "required": false }
        ],
        "tokens": [
          { "name": "id", "type": "string", "title": { "en": "Object/Event ID" } },
          { "name": "camera", "type": "string", "title": { "en": "Camera" } },
          { "name": "description", "type": "string", "title": { "en": "Description" } },
          { "name": "raw_json", "type": "string", "title": { "en": "Raw JSON" } }
        ]
      },
      {
        "id": "face_recognized",
        "title": { "en": "Face recognized" },
        "titleFormatted": { "en": "Face [[name]] recognized on [[camera]] with score at least [[min_score]]" },
        "args": [
          { "name": "camera", "type": "text", "title": { "en": "Camera" }, "placeholder": { "en": "Leave empty for any camera" }, "required": false },
          { "name": "name", "type": "text", "title": { "en": "Name" }, "placeholder": { "en": "Leave empty for any name" }, "required": false },
          { "name": "min_score", "type": "number", "title": { "en": "Minimum score" }, "min": 0, "max": 1, "step": 0.01, "placeholder": { "en": "0" }, "required": false }
        ],
        "tokens": [
          { "name": "id", "type": "string", "title": { "en": "Object/Event ID" } },
          { "name": "camera", "type": "string", "title": { "en": "Camera" } },
          { "name": "name", "type": "string", "title": { "en": "Name" } },
          { "name": "score", "type": "number", "title": { "en": "Score" } },
          { "name": "timestamp", "type": "number", "title": { "en": "Timestamp" } },
          { "name": "raw_json", "type": "string", "title": { "en": "Raw JSON" } }
        ]
      },
      {
        "id": "license_plate_recognized",
        "title": { "en": "License plate recognized" },
        "titleFormatted": { "en": "License plate [[plate]] recognized on [[camera]] named [[name]] with score at least [[min_score]]" },
        "args": [
          { "name": "camera", "type": "text", "title": { "en": "Camera" }, "placeholder": { "en": "Leave empty for any camera" }, "required": false },
          { "name": "plate", "type": "text", "title": { "en": "Plate" }, "placeholder": { "en": "Leave empty for any plate" }, "required": false },
          { "name": "name", "type": "text", "title": { "en": "Name" }, "placeholder": { "en": "Leave empty for any name" }, "required": false },
